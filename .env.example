# Upstox API Credentials for Automated Trading
# Get these by creating an app at: https://developer.upstox.com/
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here
UPSTOX_REDIRECT_URI=http://127.0.0.1:5000/

# --- TESTING SETTINGS ---
# Set DRY_RUN=true to test script without placing real orders on Upstox
DRY_RUN=true
# Set DUMMY_CAPITAL to simulate buying power if account balance is 0
DUMMY_CAPITAL=100000
